# Caddyfile.example — Cadence behind Caddy reverse proxy
# Replace radio.example.com with your domain.
#
# Caddy automatically sets X-Forwarded-For with the real client IP.
# Set CSERVER_REAL_IP_HEADER=X-Forwarded-For in cadence.env so that
# rate limiting works correctly per client (not per Caddy container IP).

radio.example.com {
    encode zstd gzip

    # Security headers
    header {
        X-Frame-Options SAMEORIGIN
        X-Content-Type-Options nosniff
        X-Robots-Tag "noindex, nofollow"
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        Referrer-Policy "same-origin"
        Permissions-Policy "geolocation=(), microphone=(), camera=()"
        -Server
    }

    # SSE endpoint — must not buffer, must not timeout
    # Cache-Control + X-Accel-Buffering prevent intermediate proxy buffering.
    handle /api/radiodata/sse {
        header Cache-Control no-cache
        header X-Accel-Buffering no
        reverse_proxy cadence:8080 {
            flush_interval -1
            transport http {
                read_timeout 0
            }
        }
    }

    # Icecast audio stream — flush immediately, no timeout
    handle /cadence1 {
        reverse_proxy icecast2:8000 {
            flush_interval -1
            transport http {
                read_timeout 0
            }
        }
    }

    # Icecast MP3 mount (uncomment if you enabled MP3 output in liquidsoap.liq)
    # handle /cadence1.mp3 {
    #     reverse_proxy icecast2:8000 {
    #         flush_interval -1
    #         transport http { read_timeout 0 }
    #     }
    # }

    # Icecast JSON status — used internally by cadence; expose only if needed
    handle /status-json.xsl {
        reverse_proxy icecast2:8000
    }

    # Cadence API + frontend
    handle {
        reverse_proxy cadence:8080
    }
}

# -----------------------------------------------------------------------
# Homelab LAN example (internal CA / split-horizon DNS / .lan domain)
# Uncomment and adjust. Use 'tls internal' for a self-signed cert.
# Set CSERVER_TRUSTED_PROXY to your Docker bridge CIDR in cadence.env.
# -----------------------------------------------------------------------
