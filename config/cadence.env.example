# Cadence environment template - copy to cadence.env

# General
CSERVER_PORT=8080
CSERVER_ROOTPATH=/app/public/
CSERVER_MUSIC_DIR=/music
CSERVER_LOGLEVEL=info
CSERVER_DEVMODE=false
CSERVER_HISTORY_SIZE=10

# Rate limiting
# Production behind Caddy: set to false (default).
# Configure rate_limit in Caddyfile instead - Caddy sees real client IPs.
# Dev / no proxy: set to true and add the redis compose profile.
# If true behind Caddy you MUST also set CSERVER_REAL_IP_HEADER and
# CSERVER_TRUSTED_PROXY or all clients share one rate limit bucket.
CSERVER_RATELIMIT_ENABLED=false
CSERVER_REAL_IP_HEADER=X-Forwarded-For
CSERVER_TRUSTED_PROXY=
CSERVER_REQRATELIMIT=5
CSERVER_ART_RATELIMIT_MAX=16
CSERVER_ART_RATELIMIT_WINDOW_MS=200000

# Database
CSERVER_DB_BACKEND=sqlite
CSERVER_SQLITE_PATH=/data/cadence.db

# Postgres (only when CSERVER_DB_BACKEND=postgres)
CSERVER_POSTGRESADDRESS=cadence-postgres
CSERVER_POSTGRESPORT=5432
CSERVER_POSTGRESUSER=postgres
POSTGRES_PASSWORD=changeme
CSERVER_POSTGRESDBNAME=cadence
CSERVER_POSTGRESTABLENAME=metadata
CSERVER_POSTGRESSSL=disable

# Redis (only when CSERVER_RATELIMIT_ENABLED=true)
CSERVER_REDISADDRESS=cadence-redis
CSERVER_REDISPORT=6379
CSERVER_REDISPASSWORD=
CSERVER_REDISDB=0

# Icecast
CSERVER_ICECAST_STATUS_URL=http://icecast2:8000
CSERVER_ICECAST_POLL_INTERVAL_MS=1000
# Set to your Caddy/CDN URL if proxying the stream
# CSERVER_PUBLIC_STREAM_URL=https://cadence.zedzulmeng.online

# Liquidsoap
CSERVER_LIQUIDSOAPADDRESS=liquidsoap
CSERVER_LIQUIDSOAPPORT=1234
CSERVER_LIQUIDSOAP_HTTP_PORT=8001
CSERVER_LIQUIDSOAP_MODE=auto
CSERVER_LIQUIDSOAP_TIMEOUT_MS=5000

# Library scan
CSERVER_SCAN_WORKERS=4
CSERVER_FSNOTIFY_DEBOUNCE_MS=3000
