# =============================================================
# Cadence Environment Configuration
# Copy to: config/cadence.env  (never commit the real file)
# =============================================================

# --- Required ---
CSERVER_MUSIC_DIR=/music

# Version is set at build time via --build-arg; override only for dev.
# CSERVER_VERSION=dev

# --- Server ---
CSERVER_PORT=:8080
# Path where built static files are served from (must match Dockerfile COPY target)
CSERVER_ROOTPATH=/app/public/
CSERVER_LOGLEVEL=info          # debug | info | warn | error
CSERVER_DEVMODE=false          # true enables /api/admin/rescan and /api/dev/skip
# CSERVER_WHITELIST_PATH=      # path to IP whitelist file (one IP/CIDR per line)

# --- Reverse proxy real-IP support (Caddy / nginx) ---
# When cadence is behind Caddy, RemoteAddr is always Caddy's container IP.
# Set this so rate limiting works per real client IP.
#
# Caddy:  CSERVER_REAL_IP_HEADER=X-Forwarded-For
# nginx:  CSERVER_REAL_IP_HEADER=X-Real-IP
# Direct (no proxy): leave empty (uses RemoteAddr)
CSERVER_REAL_IP_HEADER=X-Forwarded-For
#
# Optionally restrict which upstream IP is trusted to set that header.
# Use your Docker bridge CIDR (e.g. 172.20.0.0/16) or leave empty to trust all
# (safe on a private Docker network).
# CSERVER_TRUSTED_PROXY=172.20.0.0/16

# --- Database backend ---
CSERVER_DB_BACKEND=sqlite      # sqlite | postgres
CSERVER_DB_RETRIES=5           # attempts before fatal exit
CSERVER_DB_RETRY_DELAY_MS=3000 # ms between retries

# --- SQLite (default) ---
CSERVER_SQLITE_PATH=/data/cadence.db

# --- Postgres (set CSERVER_DB_BACKEND=postgres and use --profile postgres) ---
# POSTGRES_PASSWORD=changeme
# CSERVER_POSTGRESADDRESS=cadence-postgres
# CSERVER_POSTGRESPORT=5432
# CSERVER_POSTGRESUSER=postgres
# CSERVER_POSTGRESDBNAME=cadence
# CSERVER_POSTGRESTABLENAME=metadata
# CSERVER_POSTGRESSSL=disable

# --- Icecast ---
CSERVER_ICECAST_STATUS_URL=http://icecast2:8000
CSERVER_ICECAST_POLL_INTERVAL_MS=1000
# Public stream URL sent to the browser player.
# Leave empty to auto-build from Icecast host/mountpoint.
CSERVER_PUBLIC_STREAM_URL=

# --- Liquidsoap ---
CSERVER_LIQUIDSOAPADDRESS=liquidsoap
CSERVER_LIQUIDSOAPPORT=1234             # telnet port (no colon)
CSERVER_LIQUIDSOAP_HTTP_PORT=8001       # HTTP harbor port (no colon)
CSERVER_LIQUIDSOAP_MODE=auto            # http | telnet | auto
CSERVER_LIQUIDSOAP_TIMEOUT_MS=5000

# --- Redis (optional, --profile redis) ---
# CSERVER_REDISADDRESS=cadence-redis
# CSERVER_REDISPORT=6379                # no colon
# CSERVER_REDISPASSWORD=
# CSERVER_REDISDB=0

# --- Rate limiting (only active when Redis is connected) ---
# To disable: don't run Redis (omit --profile redis)
CSERVER_REQRATELIMIT=5                  # seconds between requests per IP
CSERVER_ART_RATELIMIT_WINDOW_MS=200000  # album art rate limit window (200s)
CSERVER_ART_RATELIMIT_MAX=16            # max art requests per window per IP

# --- Music scan ---
CSERVER_SCAN_WORKERS=4
CSERVER_PATTERN_SEPARATOR=;;
# CSERVER_TITLE_CLEANUP_PATTERNS=
# CSERVER_ARTIST_CLEANUP_PATTERNS=

# --- History ---
CSERVER_HISTORY_SIZE=10

# --- Filesystem watcher ---
CSERVER_FSNOTIFY_DEBOUNCE_MS=3000

# -------------------------------------------------------------------
# Hot-reload: sends SIGHUP to cadence to reload config + rescan.
#   docker kill -s HUP cadence
# -------------------------------------------------------------------
